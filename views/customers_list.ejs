<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Riwayat Transaksi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head><body class="bg-light py-5">
<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Daftar Pelanggan</h2>
    <div>
      <a href="/customers/add" class="btn btn-primary">Tambahkan Pelanggan Baru</a>
      <a href="/dashboard" class="btn btn-secondary">Kembali ke Dashboard</a>
    </div>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr>
            <th>ID</th>
            <th>Nama Lengkap</th>
            <th>Nomor Telepon</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% customers.forEach(c => { %>
          <tr>
            <td><%= c.id %></td>
            <td><strong><%= c.name %></strong></td>
            <td><%= c.phone %></td>
            <td class="text-center">
              <a href="/customers/edit/<%= c.id %>" class="btn btn-sm btn-warning">Edit</a>
              
              <form action="/customers/delete/<%= c.id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Hapus pelanggan ini?')">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>