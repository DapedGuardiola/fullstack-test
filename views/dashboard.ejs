<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Management</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      height: 100vh;
      display: flex;
      align-items: center;
    }
    .menu-card {
      transition: all 0.3s ease;
      border: none;
      border-radius: 15px;
    }
    .menu-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .icon-box {
      width: 60px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      margin: 0 auto 15px;
    }
  </style>
</head>
<body>

<div class="container">
  <div class="text-center mb-5">
    <h1 class="fw-bold text-dark">Sistem Manajemen</h1>
    <p class="text-muted">Pilih menu navigasi untuk mengelola data</p>
  </div>

  <div class="row g-4 justify-content-center">
    
    <div class="col-md-4 col-sm-6">
      <a href="/customers/list" class="text-decoration-none">
        <div class="card h-100 p-4 text-center shadow-sm menu-card">
          <div class="icon-box bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-people-fill fs-3"></i>
            <span style="font-size: 2rem;">👥</span>
          </div>
          <h4 class="fw-bold text-dark">Daftar Pelanggan</h4>
          <p class="text-muted small">Kelola data pelanggan dan hak akses sistem.</p>
        </div>
      </a>
    </div>

    <div class="col-md-4 col-sm-6">
      <a href="/transaction/list" class="text-decoration-none">
        <div class="card h-100 p-4 text-center shadow-sm menu-card">
          <div class="icon-box bg-success bg-opacity-10 text-success">
            <span style="font-size: 2rem;">💸</span>
          </div>
          <h4 class="fw-bold text-dark">Transaksi</h4>
          <p class="text-muted small">Pantau riwayat penjualan dan arus kas.</p>
        </div>
      </a>
    </div>

    <div class="col-md-4 col-sm-6">
      <a href="/auth/users_list" class="text-decoration-none">
        <div class="card h-100 p-4 text-center shadow-sm menu-card">
          <div class="icon-box bg-warning bg-opacity-10 text-warning">
            <span style="font-size: 2rem;">👤</span>
          </div>
          <h4 class="fw-bold text-dark">Daftar Admin</h4>
          <p class="text-muted small">Pengaturan akun petugas dan kredensial.</p>
        </div>
      </a>
    </div>

  </div>

  <div class="text-center mt-5">
    <span class="badge bg-light text-dark border p-2">
      Status: <span class="text-success">●</span> Terhubung ke Database
    </span>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>