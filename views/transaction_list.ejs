<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Riwayat Transaksi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold">Riwayat Transaksi</h2>
      <div>
        <a href="/transaction/add" class="btn btn-primary">Tambahkan Transaksi Baru</a>
        <a href="/dashboard" class="btn btn-secondary">Kembali ke Dashboard</a>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Order ID</th>
              <th>Pelanggan</th>
              <th>Total Harga</th>
              <th class="text-center">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(t => { %>
            <tr>
              <td class="fw-bold"><%= t.order_number %></td>
              <td><%= t.customer ? t.customer.name : 'Umum' %></td>
              <td class="text-success fw-bold">Rp<%= t.total_price.toLocaleString('id-ID') %></td>
              <td class="text-center">
                <a href="/transaction/detail/<%= t.id %>" class="btn btn-sm btn-info text-white">Detail</a>
                <form action="/transaction/delete/<%= t.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Hapus transaksi?')">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>