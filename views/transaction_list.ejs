<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Riwayat Transaksi</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light py-5">
  <div class="container">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-0">Riwayat Transaksi</h2>
        <small class="text-muted">Kelola dan pantau semua transaksi</small>
      </div>
      <div>
        <a href="/transaction/add" class="btn btn-primary">
          Tambah Transaksi
        </a>
        <a href="/dashboard" class="btn btn-secondary">
          Kembali ke Dashboard
        </a>
      </div>
    </div>

    <!-- FILTER CARD -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body">
        <form method="GET" action="/transaction/list" class="row g-3 align-items-end">

          <div class="col-md-4">
            <label class="form-label fw-semibold">Order ID</label>
            <input type="text" name="order_number" class="form-control"
              placeholder="Contoh: INV-001"
              value="<%= query?.order_number || '' %>">
          </div>

          <div class="col-md-4">
            <label class="form-label fw-semibold">Nama Customer</label>
            <input type="text" name="customer" class="form-control"
              placeholder="Cari nama pelanggan.."
              value="<%= query?.customer || '' %>">
          </div>

          <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">
              Filter
            </button>
            <a href="/transaction/list" class="btn btn-outline-secondary w-100">
              Reset
            </a>
          </div>

        </form>
      </div>
    </div>

    <!-- TABLE CARD -->
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Order ID</th>
              <th>Pelanggan</th>
              <th>Total Harga</th>
              <th class="text-center">Aksi</th>
            </tr>
          </thead>

          <tbody>
            <% transactions.forEach(t => { %>
            <tr>
              <td class="fw-semibold text-primary">
                <%= t.order_number %>
              </td>

              <td>
                <span class="badge bg-light text-dark border">
                  <%= t.customer ? t.customer.name : 'Umum' %>
                </span>
              </td>

              <td class="text-success fw-bold">
                Rp<%= t.total_price.toLocaleString('id-ID') %>
              </td>

              <td class="text-center">
                <a href="/transaction/detail/<%= t.id %>"
                  class="btn btn-sm btn-info text-white">
                  Detail
                </a>

                <form action="/transaction/delete/<%= t.id %>" method="POST"
                  style="display:inline;">
                  <button type="submit"
                    class="btn btn-sm btn-danger"
                    onclick="return confirm('Hapus transaksi?')">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>

            <% if (transactions.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-4 text-muted">
                Tidak ada data ditemukan
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>

      </div>
    </div>

  </div>
</body>

</html>