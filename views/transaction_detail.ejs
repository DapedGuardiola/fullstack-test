<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Detail Transaksi - <%= transaction.order_number %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-5">
<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">Detail Transaksi</h3>
        <a href="/transaction" class="btn btn-secondary btn-sm">Kembali</a>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
          <span>Order No: <%= transaction.order_number %></span>
          <span><%= new Date(transaction.createdAt).toLocaleString('id-ID') %></span>
        </div>
        <div class="card-body">
          <div class="row mb-4">
            <div class="col-6">
              <p class="text-muted mb-1">Pelanggan:</p>
              <h5 class="fw-bold"><%= transaction.customer ? transaction.customer.name : 'Umum' %></h5>
              <p class="small"><%= transaction.customer ? transaction.customer.phone : '-' %></p>
            </div>
            <div class="col-6 text-end">
              <p class="text-muted mb-1">Kasir / Admin:</p>
              <h5 class="fw-bold"><%= transaction.user ? transaction.user.username : 'System' %></h5>
            </div>
          </div>

          <table class="table table-bordered">
            <thead class="table-light">
              <tr>
                <th>Deskripsi Item</th>
                <th class="text-end">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Layanan Produk / Jasa</td>
                <td class="text-end">Rp<%= transaction.total_price.toLocaleString('id-ID') %></td>
              </tr>
            </tbody>
            <tfoot>
              <tr class="table-active">
                <th class="text-end">Total Bayar</th>
                <th class="text-end text-success">Rp<%= transaction.total_price.toLocaleString('id-ID') %></th>
              </tr>
            </tfoot>
          </table>
        </div>
        <div class="card-footer bg-white text-center py-3">
          <button class="btn btn-outline-primary btn-sm" onclick="window.print()">Cetak Struk</button>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>